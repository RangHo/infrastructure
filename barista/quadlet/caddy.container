[Unit]
Description=Containerized Caddy Reverse Proxy
Wants=caddy.volume
Requires=webserver.network
After=network-online.target

[Container]
ContainerName=caddy
Image=docker.io/library/caddy
PublishPort=80:80
PublishPort=443:443
Volume=/etc/caddy/Caddyfile:/etc/caddy/Caddyfile
Volume=caddy-data.volume:/data
Network=webserver.network

[Install]
WantedBy=default.target
