#!/bin/sh

SECRET_HOST="http://rangho-roastery.internal"

SECRET_KEY="$1"

if [ -z "$SECRET_KEY" ]; then
  echo "No name provided."
  exit 1
fi

echo "Fetching secret $SECRET_KEY..."
SECRET_VALUE="$(curl --fail-with-body $SECRET_HOST/"$SECRET_KEY".txt)"

# If the previous exit code was not 0, then the curl command failed.
if [ $? -ne 0 ]; then
    echo "Failed to fetch secret $SECRET_KEY."
    exit 1
fi

echo "Registering secret $SECRET_KEY..."
echo "$SECRET_VALUE" | /usr/bin/podman secret create --replace "$SECRET_KEY" -

echo "Done."
